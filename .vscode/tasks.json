{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "shell",
      "command": "node esbuild.js --watch",
      "label": "watch",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "fileLocation": "relative",
        "pattern": {
          "regexp": "^(.+?):(\\d+):(\\d+):\\s+(error|warning):\\s+(.+)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\[esbuild\\]",
          "endsPattern": "^\\[esbuild\\] build complete"
        }
      }
    }
  ]
}
